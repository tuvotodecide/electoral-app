{
  "expo": {
    "name": "TU VOTO DECIDE",
    "slug": "electoral-app-expo",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/ic_launcher.png",
    "scheme": "electoralappexpo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tuvotodecide",
      "buildNumber": "44",
      "icon": "./assets/images/ic_launcher.png",
      "googleServicesFile": "./native-files/GoogleService-Info.plist",
      "usesAppleSignIn": false,
      "requireFullScreen": false,
      "config": {
        "usesNonExemptEncryption": true
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Permitir a $(PRODUCT_NAME) acceder a tu cámara",
        "NSPhotoLibraryUsageDescription": "Permitir a $(PRODUCT_NAME) acceder a tu galería de fotos",
        "NSLocationWhenInUseUsageDescription": "Permitir a $(PRODUCT_NAME) acceder a tu ubicación",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Permitir a $(PRODUCT_NAME) acceder a tu ubicación en segundo plano",
        "NSFaceIDUsageDescription": "Permitir a $(PRODUCT_NAME) usar Face ID para autenticación",
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": true
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "versionCode": 63,
      "googleServicesFile": "./native-files/google-services.json",
      "package": "com.tuvotodecide",
      "usesFeatures": [
        {
          "name": "android.hardware.camera",
          "required": true
        },
        {
          "name": "android.hardware.camera.autofocus",
          "required": false
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/ic_launcher_foreground.png",
        "backgroundImage": "./assets/images/ic_launcher_background.png",
        "monochromeImage": "./assets/images/ic_launcher_monochrome.png"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.WAKE_LOCK",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.VIBRATE",
        "android.permission.FOREGROUND_SERVICE",
        "com.google.android.c2dm.permission.RECEIVE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "com.appelectoral",
              "host": "shared.request"
            },
            {
              "scheme": "com.appelectoral",
              "host": "shared.response"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "useLegacyPackaging": false,
            "enableMinifyInReleaseBuilds": true
          },
          "ios": {
            "deploymentTarget": "16.0",
            "useFrameworks": "static",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAuth",
              "RNFBDatabase",
              "RNFBFunctions",
              "RNFBMessaging",
              "VisionCamera"
            ]
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Permitir a $(PRODUCT_NAME) acceder a tu cámara",
          "microphonePermission": false
        }
      ],
      [
        "./plugins/withAndroidKeystore",
        {
          "keystorePath": "./native-files/keystores/identity-release.keystore"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir a $(PRODUCT_NAME) acceder a tu cámara",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "note": "Use SENTRY_AUTH_TOKEN env to authenticate with Sentry.",
          "project": "react-native",
          "organization": "tu-voto-decide"
        }
      ],
      "@react-native-firebase/app",
      "expo-secure-store",
      "expo-localization",
      "./plugins/withIOSCodesigning",
      "./plugins/withIOSNativeModules",
      "./plugins/withNativeModules",
      "./plugins/withIOSOrientation"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "fe4834f2-1559-495f-ace5-22695149ba9a"
      }
    }
  }
}
