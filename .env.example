# Sentry DSN used by the app at runtime to send events.
# Required for Sentry runtime events in iOS/TestFlight and Android.
# SENTRY_AUTH_TOKEN is not required for runtime events; it is only used to upload source maps during build.
SENTRY_DSN_KEY=

# Temporary flag to validate Sentry runtime events in iOS/TestFlight.
# Keep false or empty for final production builds.
# Use true only for a temporary TestFlight validation build.
SENTRY_TESTFLIGHT_SMOKE_TEST=false
